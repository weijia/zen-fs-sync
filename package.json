{
  "name": "zen-fs-sync",
  "version": "0.2.5",
  "description": "Sync engine for ZenFS virtual file system instances",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "zenfs",
    "filesystem",
    "sync",
    "config",
    "virtual-fs"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@zenfs/core": ">=0.6.0"
  },
  "devDependencies": {
    "@zenfs/core": "^2.5.7",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
